# Локально: скопируйте в .env и заполните (файл .env в git не попадает)
BOT_TOKEN=123456789:your-bot-token-here
ADMIN_ID=0

# Локальная разработка — polling. В облаке ставьте USE_WEBHOOK=1
USE_WEBHOOK=0

# Опционально: отдельный секрет webhook (иначе выводится из BOT_TOKEN)
# WEBHOOK_SECRET=

# Локально: HTTPS-туннель (ngrok/cloudflared). В Render не нужно — подставится RENDER_EXTERNAL_URL
WEBAPP_URL=

# Railway: можно задать PUBLIC_URL=https://your-app.up.railway.app
# PUBLIC_URL=

# Active-Passive cluster — см. CLUSTER.md
CLUSTER_ROLE=primary
# CLUSTER_PEER_URL=https://your-app.vercel.app
# REDIS_URL=redis://default:pass@host:6379
# CRON_SECRET=random-secret-for-vercel-cron
# KOYEB_PUBLIC_URL=
# VERCEL_URL=

# Общая БД для Koyeb + Vercel (обязательно Postgres в продакшн)
# DATABASE_URL=postgresql+asyncpg://user:password@host/db
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
KEEP_ALIVE_INTERVAL_MINUTES=10
